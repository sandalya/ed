          {
            "type": "text_contains",
            "value": "Довжина"
          }
        ]
      },
      {
        "action": "click_intent",
        "intent": "50см",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "text_contains",
            "value": "Маса"
          }
        ]
      },
      {
        "action": "send",
        "text": "30",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "has_buttons",
            "value": true
          },
          {
            "type": "text_contains",
            "value": "Покриття"
          }
        ]
      },
      {
        "action": "click_intent",
        "intent": "Срібло біле",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "has_buttons",
            "value": true
          },
          {
            "type": "text_contains",
            "value": "Застібка"
          }
        ]
      },
      {
        "action": "click_intent",
        "intent": "Карабін",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "has_buttons",
            "value": true
          },
          {
            "type": "text_contains",
            "value": "Додатково"
          }
        ]
      },
      {
        "action": "click_intent",
        "intent": "Немає",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "text_contains",
            "value": "телефон"
          }
        ]
      },
      {
        "action": "send",
        "text": "Іван +38099 123 45 67",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "has_buttons",
            "value": true
          },
          {
            "type": "text_contains",
            "value": "уточнити"
          }
        ]
      },
      {
        "action": "click_intent",
        "intent": "Немає",
        "assertions": [
          {
            "type": "no_error"
          },
          {
            "type": "text_contains",
            "value": "Замовлення"
          },
          {
            "type": "order_saved",
            "file_path": "/home/sashok/.openclaw/workspace/insilver-v3/data/orders/orders.json",
            "last_contains": {
              "type": "ланцюжок",
              "Плетіння": "Бісмарк",
              "Довжина": "50см"
            }
          },
          {
            "type": "admin_received"
          }
        ]
      }
    ],
    "context": "Повна воронка happy path: Бісмарк, 50см, 30г, срібло, карабін, без додаткового",
    "tags": [
      "happy_path",
      "funnel",
      "full"
    ],
    "expected_behavior": {
      "should_respond_in_ukrainian": true,
      "should_complete_order": true
    }
  },
